{
  "entities": {
    "Place": {
      "title": "Place",
      "description": "A physical location with urban intelligence data",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "category": { "type": "string" },
        "address": { "type": "string" },
        "coordinates": {
          "type": "object",
          "properties": {
            "lat": { "type": "number" },
            "lng": { "type": "number" }
          }
        },
        "crowdDensity": { "type": "number" },
        "aqi": { "type": "number" },
        "pm25": { "type": "number" },
        "trend": { "type": "string", "enum": ["INCREASING", "DECREASING", "STABLE"] },
        "waitTime": { "type": "number" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "category", "crowdDensity", "aqi"]
    },
    "Report": {
      "title": "Report",
      "description": "A user-submitted report about crowd conditions",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "placeId": { "type": "string" },
        "userId": { "type": "string" },
        "timestamp": { "type": "number" },
        "level": { "type": "string", "enum": ["LOW", "MODERATE", "HIGH"] },
        "waitTime": { "type": "number" }
      },
      "required": ["id", "placeId", "userId", "timestamp", "level"]
    }
  },
  "firestore": {
    "/places/{placeId}": {
      "schema": "Place",
      "description": "Collection of places with live intelligence"
    },
    "/reports/{reportId}": {
      "schema": "Report",
      "description": "Real-time user reports"
    }
  }
}
